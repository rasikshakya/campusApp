{
  "name": "campusapp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "mobile",
    "api",
    "shared"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=mobile",
    "api": "npm run dev --workspace=api",
    "api:migrate": "npm run migrate --workspace=api",
    "api:seed": "npm run seed --workspace=api"
  },
  "dependencies": {
    "bcrypt": "6.0.0",
    "jsonwebtoken": "9.0.3"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/jsonwebtoken": "9.0.10"
  }
}
